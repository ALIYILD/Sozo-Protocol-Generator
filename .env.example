# Database
DATABASE_URL=postgresql+asyncpg://sozo:sozo_dev_password@localhost:5432/sozo

# Redis
SOZO_CELERY_BROKER_URL=redis://localhost:6379/0
SOZO_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Auth
SOZO_AUTH_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Anthropic (for LLM-powered protocol composition)
ANTHROPIC_API_KEY=sk-ant-...

# NCBI / PubMed
NCBI_EMAIL=your_email@example.com
NCBI_API_KEY=your_ncbi_api_key_here

# Sozo settings
SOZO_OUTPUT_DIR=outputs/
SOZO_CACHE_DIR=data/raw/pubmed_cache/
SOZO_LOG_LEVEL=INFO
SOZO_STRICT_EVIDENCE=false
SOZO_LLM_ADAPTER_ENABLED=false

# Optional
OPENAI_API_KEY=

# Phase 8 — Evidence ingestion (all optional, improve rate limits / coverage)
SEMANTIC_SCHOLAR_API_KEY=    # https://www.semanticscholar.org/product/api
CONSENSUS_API_KEY=           # https://consensus.app/api/ — structured academic search
